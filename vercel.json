{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "^/includes/(.*)$",
      "status": 404
    },
    {
      "src": "^/(.*)\\.sql$",
      "status": 404
    },
    {
      "src": "^/(.*)\\.php$",
      "dest": "/api/index.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.php"
    }
  ]
}