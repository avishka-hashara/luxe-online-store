{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "pages/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "src": "^/admin$",
      "dest": "/admin/index.php"
    },
    {
      "src": "^/includes/(.*)$",
      "status": 404
    },
    {
      "src": "^/(.*)\\.sql$",
      "status": 404
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)$",
      "dest": "/$1"
    }
  ]
}